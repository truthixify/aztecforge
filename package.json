{
  "name": "aztecforge",
  "version": "0.1.0",
  "private": true,
  "description": "Private community incentive platform built on Aztec Network",
  "scripts": {
    "build:contracts": "cd contracts && ./build.sh",
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server start:dev",
    "build:client": "pnpm --filter client build",
    "build:server": "pnpm --filter server build",
    "test:contracts": "cd contracts && ./test.sh",
    "test:client": "pnpm --filter client test",
    "test:server": "pnpm --filter server test",
    "test": "pnpm test:contracts && pnpm test:server && pnpm test:client",
    "lint": "pnpm --filter client lint && pnpm --filter server lint",
    "deploy": "npx tsx scripts/deploy.ts",
    "codegen": "cd contracts && aztec codegen target --outdir ../client/src/artifacts"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@aztec/accounts": "^4.2.0",
    "@aztec/aztec.js": "^4.2.0",
    "@aztec/noir-contracts.js": "^4.2.0",
    "@aztec/wallets": "^4.2.0",
    "tsx": "^4.21.0"
  }
}
